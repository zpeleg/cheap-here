# Generated store data — lives in CF Pages, not in git
frontend/public/data/*.json
!frontend/public/data/.gitkeep

# Build artifacts
frontend/dist/
etl/dist/

# Dependencies
frontend/node_modules/
etl/node_modules/

# DuckDB on-disk files (ETL uses :memory: but guard against accidents)
*.duckdb
*.db

# Logs
*.log

# Scraper session cookies (may contain credentials)
*_cookies.txt

# macOS
.DS_Store

.claude
.vscode
